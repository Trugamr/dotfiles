#!/usr/bin/env bash
set -euo pipefail

version="{{ .zellij_version }}"

installed="$(zellij --version 2>/dev/null | awk '{print $2}' || true)"
if [ "$installed" = "$version" ]; then
  exit 0
fi

case "$(dpkg --print-architecture)" in
  amd64) arch="x86_64" ;;
  arm64) arch="aarch64" ;;
  *) echo "unsupported architecture: $(dpkg --print-architecture)" >&2; exit 1 ;;
esac

mkdir -p "$HOME/.local/bin"
curl -fsSL "https://github.com/zellij-org/zellij/releases/download/v${version}/zellij-${arch}-unknown-linux-musl.tar.gz" \
  | tar -xz -C "$HOME/.local/bin" zellij
