theme "muah"
simplified_ui true

keybinds {
    // Ctrl t (tab mode) then w → launch the room tab/pane switcher
    // github.com/rvcas/room, installed via .chezmoiexternal.toml.tmpl
    tab {
        bind "w" {
            LaunchOrFocusPlugin "file:~/.config/zellij/plugins/room.wasm" {
                floating true
                move_to_focused_tab true
                ignore_case true
                quick_jump true
            }
            SwitchToMode "normal";
        }
    }
}
